## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio Code design-time settings
.vscode/

# CoreCLR debugger generate settings
launch.json

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# AspNet5 temporary files
InternalCache/

# StyleCop
StyleCop.Cache

# Backup & temp files from Optimise Class
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Entity Framework ESent artifacts
*.msl
*.ssdl
*.csdl
*.dat
*.edmx.sqlce.1
*.PrecompiledViews.dll
*.pfx
*.publishsettings

# NUnit
TestResult.xml
nunit-*.xml

# Telerik UI for ASP.NET AJAX
lib/Telerik.Web.UI.DialogHandler.lic
lib/Telerik.Web.UI.SpellCheckHandler.lic

# Bower
bower_components/

# Node.js
node_modules/
npm-debug.log
yarn-error.log

# TypeScript
*.js
*.js.map
*.d.ts
!wwwroot/js/**/*.js
!wwwroot/js/**/*.d.ts

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# If using the Package Reference model, all packages are stored in the global-packages location
# and the "packages" folder will be unused.

# JetBrains Rider
.idea/
*.sln.iml

# JustMock
*.jmconfig

# CodeRush
.cr/

# Python Tools for Visual Studio
*.pyc

# Cake
tools/ cakes/

# Tabs Studio
*.tss

# MyGet
.myget

# OpenCover
*.opencoverxml

# Azure Functions local settings
local.settings.json

# Visual Studio Online build artifacts
_build/

# AppInsights config
ApplicationInsights.config

# Others
.DS_Store
*.orig
*.bak

# Rider
.idea/
.shelf/

# Local history
.history/

# User-defined overrides
appsettings.Development.json
appsettings.Local.json
publish/
